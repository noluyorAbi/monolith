# Optional. Without it the public contributions calendar is scraped instead,
# which works fine but is rate limited by GitHub rather than by your token.
GITHUB_TOKEN=

# Optional. Without it checkout runs in demo mode: real order records, no charge.
STRIPE_SECRET_KEY=

# Guards /studio. Optional in development; REQUIRED in production, where an
# unset key locks the studio out entirely rather than publishing the order
# queue. Visit /studio?key=<value> once; the key is exchanged for a signed,
# 12-hour session cookie and never stored anywhere. Rotating this value logs
# every open session out immediately.
MONOLITH_ADMIN_KEY=
